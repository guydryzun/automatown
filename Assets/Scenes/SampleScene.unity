  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: 'If the cell is alive, and it has 2 or 3 living cells in it''s

    neighbourhood,
    it will survive. Otherwise it dies.

    If the cell is dead and has 3 living
    cells in it''s

    neighbourhood, it will be born and become alive.

    Otherwise
    it keeps being dead. This ruleset is also

    described as B3/S23 meaning dead
    cells with 3 neigbours

    are born and living cells with 3 or 2 neighbours
    survive.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
